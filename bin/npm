#!/bin/sh
set -eu

if [ -n "${PUBLIC_SECRETS_NPM_BIN:-}" ] && [ -x "${PUBLIC_SECRETS_NPM_BIN}" ]; then
  exec "${PUBLIC_SECRETS_NPM_BIN}" "$@"
fi

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"
ROOT_DIR="$(CDPATH= cd -- "${SCRIPT_DIR}/.." && pwd)"

for candidate in \
  "${ROOT_DIR}/.tools/node/bin/npm" \
  "${ROOT_DIR}/.node/bin/npm" \
  "/opt/homebrew/bin/npm" \
  "/usr/local/bin/npm" \
  "/opt/local/bin/npm" \
  "/private/tmp/node-v24.13.1-darwin-arm64/bin/npm" \
  "/tmp/node-v24.13.1-darwin-arm64/bin/npm"
do
  if [ -x "${candidate}" ]; then
    candidate_dir="$(CDPATH= cd -- "$(dirname "${candidate}")" && pwd)"
    PATH="${candidate_dir}:${PATH}" exec "${candidate}" "$@"
  fi
done

if command -v npm >/dev/null 2>&1; then
  exec "$(command -v npm)" "$@"
fi

echo "Kein nutzbares npm-Binary gefunden. Setze PUBLIC_SECRETS_NPM_BIN oder installiere Node lokal." >&2
exit 127
